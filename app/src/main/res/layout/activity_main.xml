<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A0030"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:minHeight="600dp">

        <!-- Logo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💸"
            android:textSize="72sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="YAPE LISTENER"
            android:textSize="28sp"
            android:textColor="#E91E8C"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Te avisa cuando llega un Yape"
            android:textSize="14sp"
            android:textColor="#AAAAAA"
            android:layout_marginBottom="48dp" />

        <!-- Status card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#2D0050"
            android:padding="24dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ESTADO"
                android:textSize="11sp"
                android:textColor="#888888"
                android:letterSpacing="0.2"
                android:layout_marginBottom="8dp" />

            <ImageView
                android:id="@+id/ivStatus"
                android:layout_width="0dp"
                android:layout_height="0dp" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Verificando..."
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <!-- How it works -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#2D0050"
            android:padding="24dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CÓMO FUNCIONA"
                android:textSize="11sp"
                android:textColor="#888888"
                android:letterSpacing="0.2"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1️⃣  Da el permiso de notificaciones\n\n2️⃣  La app se activa en segundo plano\n\n3️⃣  Cuando llegue un Yape, escucharás:\n\n      ¡Yape! De [nombre], [monto]"
                android:textSize="14sp"
                android:textColor="#CCCCCC"
                android:lineSpacingMultiplier="1.3" />
        </LinearLayout>

        <!-- Permission button -->
        <Button
            android:id="@+id/btnPermission"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Dar permiso de notificaciones"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#E91E8C"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="La app solo lee notificaciones de Yape.\nNo accede a otros datos."
            android:textSize="12sp"
            android:textColor="#666666"
            android:gravity="center"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</ScrollView>
